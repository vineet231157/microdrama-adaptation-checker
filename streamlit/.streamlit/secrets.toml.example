# Copy to secrets.toml (git-ignored) for local dev, or paste into the
# Streamlit Community Cloud "Secrets" box. The app auto-reads GEMINI_API_KEY.
GEMINI_API_KEY = "your-gemini-api-key"

# Optional: paste a service-account key here to preload Drive mode instead of
# uploading the JSON each time (advanced).
# [gcp_service_account]
# type = "service_account"
# project_id = "..."
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "adaptation-bot@your-project.iam.gserviceaccount.com"
# client_id = "..."
# token_uri = "https://oauth2.googleapis.com/token"
