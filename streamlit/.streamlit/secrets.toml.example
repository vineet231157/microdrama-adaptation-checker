# ─────────────────────────────────────────────────────────────────────────────
# Copy to  .streamlit/secrets.toml  (git-ignored) for local hosting, OR paste
# these into the Streamlit Community Cloud "Secrets" box.
#
# The API key stays SERVER-SIDE: when GEMINI_API_KEY is set here, the app hides
# the key input entirely and NEVER shows or sends the key to a user's browser.
# Users interact with the tool without ever seeing or entering the key.
# ─────────────────────────────────────────────────────────────────────────────

# Your Gemini key — configured once by YOU (the host). Keep this file private.
GEMINI_API_KEY = "your-gemini-api-key"

# Optional but RECOMMENDED when you host publicly: a shared team password.
# Users must enter THIS PASSWORD (not the API key) before using the tool, so
# strangers can't use your hosted app and burn your Gemini quota.
APP_PASSWORD = "choose-a-team-password"

# Optional: preload a service account for Drive mode (advanced) instead of
# uploading the JSON each time.
# [gcp_service_account]
# type = "service_account"
# project_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "adaptation-bot@your-project.iam.gserviceaccount.com"
# token_uri = "https://oauth2.googleapis.com/token"
