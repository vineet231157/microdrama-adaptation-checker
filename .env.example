# ── Backend (.env consumed by docker-compose api + worker) ──────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro
GEMINI_FALLBACKS=gemini-2.5-pro,gemini-2.0-flash,gemini-1.5-flash

# Public URL of THIS backend (used to build absolute download links).
# In prod set to your Render/Railway/Cloud Run URL, e.g. https://api.yourapp.com
PUBLIC_BASE_URL=http://localhost:8000

# Comma-separated origins allowed to call the API (your Vercel frontend URL).
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# OCR
OCR_LANG=en
OCR_USE_GPU=false          # set true on a GPU host
OCR_CONF_THRESHOLD=75
OCR_SIM_THRESHOLD=80

# Redis (docker-compose overrides these to the internal service host)
REDIS_URL=redis://redis:6379/0
